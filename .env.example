
# Supabase Configuration
# Copy this file to .env and replace with your actual credentials
# IMPORTANT: Never commit the .env file to version control!

# Your Supabase project URL (format: https://your-project-ref.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous/public key (starts with eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# To get your credentials:
# 1. Go to https://supabase.com/dashboard/project/your-project-id/settings/api
# 2. Copy the "Project URL" and "anon public" key
# 3. Paste them above
# 4. Restart your Expo development server
